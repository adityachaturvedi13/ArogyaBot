# Google Gemini API Key
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Supabase Configuration
# Create a free project at: https://supabase.com
# No auth needed — anon key is safe to expose to the client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key — SERVER-SIDE ONLY
# Found in: Supabase Dashboard → Settings → API → service_role key
# ⚠️  NEVER expose this to the client or commit to version control
SUPABASE_SERVICE_ROLE_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_APP_NAME=ArogyaBot
